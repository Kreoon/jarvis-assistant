# WhatsApp Meta Cloud API
WHATSAPP_TOKEN=your_whatsapp_access_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_VERIFY_TOKEN=your_custom_verify_token_any_string
WHATSAPP_ALLOWED_NUMBERS=573001234567,573009876543

# AI APIs
ANTHROPIC_API_KEY=your_anthropic_key
OPENAI_API_KEY=your_openai_key
GEMINI_API_KEY=your_gemini_key

# Obsidian Vault (GitHub repo)
OBSIDIAN_REPO_URL=https://github.com/your-user/your-obsidian-vault.git
OBSIDIAN_VAULT_PATH=./vault

# Server
PORT=3000
WEBHOOK_URL=https://your-vps-domain.com/webhook

# Web Search (Serper API - 2500 free searches/month)
SERPER_API_KEY=
# Email (Resend API)
RESEND_API_KEY=
RESEND_FROM_EMAIL=jarvis@kreoon.com
# Services to monitor (comma separated)
SERVICES_TO_CHECK=https://kreoon.app,https://dev.kreoon.com
# Whisper vocabulary hints
WHISPER_VOCABULARY=KREOON,Infiny,Infiny Latam,Obsidian,Supabase,Vercel,UGC Colombia,Alexander Cast
